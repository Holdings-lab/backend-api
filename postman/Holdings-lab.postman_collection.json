        {
          "name": "POST /ml/content/policy-feed",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"limit\": 10,\n  \"category\": \"all\",\n  \"userId\": {{userId}},\n  \"dateFrom\": \"\",\n  \"dateTo\": \"\"\n}"
            },
            "url": "{{mlBaseUrl}}/ml/content/policy-feed"
          }
        },
        {
          "name": "POST /ml/signal",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"now\",\n  \"source\": \"postman\"\n}"
            },
            "url": "{{mlBaseUrl}}/ml/signal"
          }
        }
      ]
    }
  ]
}
